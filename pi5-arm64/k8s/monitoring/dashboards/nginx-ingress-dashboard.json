{
  "__inputs": [],
  "__requires": [],
  "description": "NGINX Ingress Controller Production dashboard - Displays request metrics, latency, and active connections for the NGINX Ingress Controller.",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests per second",
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests{job=\"$job\"}[5m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests by Host",
      "targets": [
        {
          "expr": "sum by (host) (rate(nginx_ingress_controller_requests{job=\"$job\"}[5m]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests by Host and Status",
      "targets": [
        {
          "expr": "sum by (host,status) (rate(nginx_ingress_controller_requests{job=\"$job\"}[5m]))",
          "legendFormat": "{{host}} {{status}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP 5xx Error Rate",
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests{job=\"$job\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Latency p95",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(nginx_ingress_controller_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Active Connections",
      "targets": [
        {
          "expr": "nginx_ingress_controller_nginx_process_connections{job=\"$job\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Current Request Rate",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(nginx_ingress_controller_requests{job=\"$job\"}[5m]))"
        }
      ],
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "req/s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "kubernetes",
    "nginx-ingress",
    "production"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "label": "Data source",
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "name": "job",
        "type": "query",
        "label": "Prometheus Job",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(nginx_ingress_controller_build_info, job)",
        "refresh": 1,
        "current": {
          "text": "nginx-ingress",
          "value": "nginx-ingress"
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
      "1d",
      "7d",
      "30d"
    ],
    "time_options": [
      "5m",
      "15m",
      "1h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d",
      "30d"
    ]
  },
  "timezone": "browser",
  "title": "NGINX Ingress Controller Production Dashboard",
  "uid": "nginx-ingress-prod-dashboard",
  "version": 1
}